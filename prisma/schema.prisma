generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trees     Tree[]
}

model Tree {
  id               String         @id @default(uuid())
  familyName       String
  motto            String?
  origin           String?
  established      String?
  ownerId          String
  owner            User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  isPublic         Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  members          Member[]
  timelineEvents   TimelineEvent[]
}

model Member {
  id             String         @id @default(uuid())
  treeId         String
  tree           Tree           @relation(fields: [treeId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  gender         String         // male, female, other
  dateOfBirth    String
  dateOfDeath    String?
  isAlive        Boolean        @default(true)
  photo          String?
  occupation     String?
  city           String?
  state          String?
  country        String?
  bio            String?
  achievements   String?        // comma-separated or JSON string
  hobbies        String?        // comma-separated or JSON string
  education      String?
  email          String?
  phone          String?
  generation     Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  // Relationships
  relationshipsAsMember1 Relationship[] @relation("Member1")
  relationshipsAsMember2 Relationship[] @relation("Member2")
}

model Relationship {
  id          String   @id @default(uuid())
  member1Id   String
  member2Id   String
  type        String   // PARENT, SPOUSE, SIBLING
  member1     Member   @relation("Member1", fields: [member1Id], references: [id], onDelete: Cascade)
  member2     Member   @relation("Member2", fields: [member2Id], references: [id], onDelete: Cascade)

  @@unique([member1Id, member2Id, type])
}

model TimelineEvent {
  id          String   @id @default(uuid())
  treeId      String
  tree        Tree     @relation(fields: [treeId], references: [id], onDelete: Cascade)
  date        String
  year        Int
  title       String
  description String
  type        String   // birth, death, marriage, achievement, event, migration
  memberId    String?
  memberName  String?
  location    String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
